/**
 * Implements hook_theme().
 */
function laci_indiana_theme() {
  return [
    'laci_help_block' => [
      'variables' => [],
      'template' => 'laci-help-block',
    ],
  ];
}

/**
 * Implements hook_form_alter().
 */
function laci_indiana_form_alter(array &$form, \Drupal\Core\Form\FormStateInterface $form_state, string $form_id) {
  // Filter the authority type dropdown on the Authority Source node form.
  if ($form_id === 'node_authoritativesource_form' || $form_id === 'node_authoritativesource_edit_form') {
    _laci_indiana_filter_authority_type_options($form);
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for views_exposed_form.
 */
function laci_indiana_form_views_exposed_form_alter(array &$form, \Drupal\Core\Form\FormStateInterface $form_state) {
  // Filter the term_node_tid_depth exposed filter on Views forms.
  // This filter uses stdClass objects with nested 'option' arrays
  // where keys are taxonomy term IDs.
  if (isset($form['term_node_tid_depth']['#options'])) {
    _laci_indiana_filter_term_depth_options($form['term_node_tid_depth']['#options']);
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for node_authoritativesource_form.
 */
function laci_indiana_form_node_authoritativesource_form_alter(array &$form, \Drupal\Core\Form\FormStateInterface $form_state) {
  _laci_indiana_filter_authority_type_options($form);
}

/**
 * Implements hook_form_FORM_ID_alter() for node_authoritativesource_edit_form.
 */
function laci_indiana_form_node_authoritativesource_edit_form_alter(array &$form, \Drupal\Core\Form\FormStateInterface $form_state) {
  _laci_indiana_filter_authority_type_options($form);
}

/**
 * Get the list of allowed authority type term IDs based on per-user prefs.
 *
 * @return int[]|null
 *   Array of allowed term IDs, or NULL if filtering is disabled.
 */
function _laci_indiana_get_allowed_type_ids() {
  $account = \Drupal::currentUser();
  $enabled = \Drupal\laci_indiana\Form\LaciUserPreferencesForm::getUserEnabledTypes($account);

  if (empty($enabled)) {
    return NULL;
  }

  // Also include parent term IDs that have enabled children.
  $tree = \Drupal::entityTypeManager()->getStorage('taxonomy_term')
    ->loadTree('authoritativesourcetype', 0, 2, FALSE);
  $parent_children = [];
  foreach ($tree as $term) {
    if ($term->depth > 0 && !empty($term->parents[0])) {
      $parent_children[$term->parents[0]][$term->tid] = $term->tid;
    }
  }
  $allowed = $enabled;
  foreach ($parent_children as $parent_tid => $children) {
    foreach ($children as $child_tid) {
      if (in_array($child_tid, $allowed, TRUE)) {
        $allowed[] = (int) $parent_tid;
        break;
      }
    }
  }
  return array_unique($allowed);
}

/**
 * Filter term_node_tid_depth options where values are stdClass objects.
 *
 * The Views exposed filter for taxonomy terms uses stdClass objects with
 * an 'option' property containing [term_id => label] arrays.
 */
function _laci_indiana_filter_term_depth_options(array &$options) {
  $allowed = _laci_indiana_get_allowed_type_ids();
  if ($allowed === NULL) {
    return;
  }

  foreach ($options as $key => $value) {
    if ($key === 'All') {
      continue;
    }
    $term_ids = [];
    if (is_object($value)) {
      $arr = (array) $value;
      if (isset($arr['option']) && is_array($arr['option'])) {
        $term_ids = array_map('intval', array_keys($arr['option']));
      }
    }
    elseif (is_numeric($key) && (int) $key > 10) {
      $term_ids = [(int) $key];
    }

    if (empty($term_ids)) {
      continue;
    }

    $keep = FALSE;
    foreach ($term_ids as $tid) {
      if (in_array($tid, $allowed, TRUE)) {
        $keep = TRUE;
        break;
      }
    }
    if (!$keep) {
      unset($options[$key]);
    }
  }
}

/**
 * Filter authority type options based on per-user preferences.
 */
function _laci_indiana_filter_authority_type_options(array &$form) {
  $allowed = _laci_indiana_get_allowed_type_ids();

  // Add "Edit visible types" link below the field_type widget.
  $current_user = \Drupal::currentUser();
  $prefs_url = \Drupal\Core\Url::fromRoute('laci_indiana.user_preferences', ['user' => $current_user->id()]);
  $form['field_type']['#suffix'] = '<div class="laci-edit-types-link"><a href="' . $prefs_url->toString() . '">' . t('Edit visible authority types') . '</a></div>';

  if ($allowed === NULL) {
    return;
  }

  // Check field_type structure.
  if (!isset($form['field_type']['widget']['#options'])) {
    return;
  }

  // Natural sort the options.
  _laci_indiana_natural_sort_options($form['field_type']['widget']['#options']);

  // Load the taxonomy tree to determine parent-child relationships.
  $tree = \Drupal::entityTypeManager()->getStorage('taxonomy_term')
    ->loadTree('authoritativesourcetype', 0, 2, FALSE);

  // Build a map: parent_tid => [child_tid, ...]
  $parent_children = [];
  foreach ($tree as $term) {
    if ($term->depth > 0 && !empty($term->parents[0])) {
      $parent_children[$term->parents[0]][$term->tid] = $term->tid;
    }
  }

  if (isset($form['field_type']['widget']['#options'])) {
    // Handle optgroup structure: options may be [parent_name => [tid => label, ...]]
    // or flat [tid => label]. Check first non-_none key type.
    $first_key = array_key_first($form['field_type']['widget']['#options']);
    // Skip the "_none" placeholder to determine actual structure.
    $check_key = $first_key;
    if ($check_key === '_none') {
      $keys = array_keys($form['field_type']['widget']['#options']);
      $check_key = $keys[1] ?? NULL;
    }
    $is_optgroup = is_string($check_key) && !ctype_digit($check_key);

    if ($is_optgroup) {
      // Optgroup structure: filter within each group.
      foreach ($form['field_type']['widget']['#options'] as $group_label => &$group_options) {
        if (!is_array($group_options)) {
          continue;
        }
        foreach ($group_options as $tid => $label) {
          $tid = (int) $tid;
          if (!in_array($tid, $allowed, TRUE)) {
            unset($group_options[$tid]);
          }
        }
        // Remove empty groups.
        if (empty($group_options)) {
          unset($form['field_type']['widget']['#options'][$group_label]);
        }
      }
    }
    else {
      // Flat structure: filter directly.
      foreach ($form['field_type']['widget']['#options'] as $tid => $label) {
        $tid_int = (int) $tid;
        if (in_array($tid_int, $allowed, TRUE)) {
          continue;
        }
        // Keep parent if it has enabled children.
        if (isset($parent_children[$tid_int])) {
          $has_enabled_child = FALSE;
          foreach ($parent_children[$tid_int] as $child_tid) {
            if (in_array($child_tid, $allowed, TRUE)) {
              $has_enabled_child = TRUE;
              break;
            }
          }
          if ($has_enabled_child) {
            continue;
          }
        }
        unset($form['field_type']['widget']['#options'][$tid]);
      }
    }
  }
}

/**
 * Natural sort an options array so numbered items sort numerically.
 *
 * Handles both flat arrays and arrays with a leading '_none' key.
 * Sorts "Title 1" before "Title 10", and parent types alphabetically.
 */
function _laci_indiana_natural_sort_options(array &$options) {
  // Preserve _none at the top.
  $none = NULL;
  if (isset($options['_none'])) {
    $none = $options['_none'];
    unset($options['_none']);
  }

  // Sort using natural comparison with numeric prefix priority.
  uasort($options, function ($a, $b) {
    // Handle string labels or nested arrays.
    $label_a = is_string($a) ? $a : (is_array($a) ? reset($a) : (string) $a);
    $label_b = is_string($b) ? $b : (is_array($b) ? reset($b) : (string) $b);

    // Items starting with "-" are children (indented), group them after
    // their parent by stripping the prefix for comparison.
    $is_child_a = str_starts_with($label_a, '-');
    $is_child_b = str_starts_with($label_b, '-');

    // Extract "Title N" pattern for numeric sort.
    $has_title_a = preg_match('/Title\s+(\d+)/', $label_a, $ma);
    $has_title_b = preg_match('/Title\s+(\d+)/', $label_b, $mb);

    // Title items sort among themselves numerically.
    if ($has_title_a && $has_title_b) {
      return (int) $ma[1] <=> (int) $mb[1];
    }

    // Title items sort after non-title items within the same group.
    if ($has_title_a && !$has_title_b) {
      return $is_child_b ? -1 : 1;
    }
    if (!$has_title_a && $has_title_b) {
      return $is_child_a ? 1 : -1;
    }

    return strnatcasecmp($label_a, $label_b);
  });

  // Restore _none at the top.
  if ($none !== NULL) {
    $options = ['_none' => $none] + $options;
  }
}
